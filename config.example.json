{
  "configSchemaVersion": 9,
  "name": "Example VPN",
  "backend": "myvpn_tunnel",
  "adapterKind": "auto",
  "preferDtls": false,
  "useOpenconnectBackend": true,
  "openconnectNoDtls": true,
  "openconnectDpdSeconds": 300,
  "openconnectReconnectTimeoutSeconds": 60,
  "openconnectInterfaceAlias": "MyVpnClient",
  "openconnectForceInterfaceAlias": false,
  "authRetryCount": 0,
  "pppNegotiationTimeoutSeconds": 90,
  "tunnelIdleTimeoutSeconds": 0,
  "terminateGraceSeconds": 2,
  "keepTunnelAliveWhileAppRunning": false,
  "keepTunnelAliveReconnectDelaySeconds": 10,
  "keepTunnelAliveMaxReconnects": 0,
  "server": "vpn.example.com:8443",
  "username": "",
  "password": "",
  "protocol": "fortinet",
  "servercert": "",
  "authgroup": "",
  "autoPushMfa": true,
  "mfaBlankResponses": 3,
  "mfaResponse": "",
  "notifySessionExpiryWarningMinutes": 10,
  "logPath": "",
  "postConnectNetworkFix": true,
  "tapInterfaceAlias": "Local Area Connection",
  "tapInterfaceMetric": 1,
  "vpnDnsServers": [],
  "networkFixWaitSeconds": 90,
  "networkCheckRouteWaitSeconds": 20
}
